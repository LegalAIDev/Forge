# Backend origin for API calls, with NO trailing /api, e.g.
#   VITE_API_BASE_URL=https://forge-api.example.com
#
# Leave empty for same-origin "/api" — the default, used by the Vite dev proxy
# and by a Netlify "/api/*" redirect proxy (Option A in netlify.toml).
# Only set this for the cross-origin setup (Option B), which requires CORS on
# the backend. This is a build-time variable: set it in the Netlify UI.
VITE_API_BASE_URL=
