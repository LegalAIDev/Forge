# Frontier model (required for engine calls; unit tests run without it)
ANTHROPIC_API_KEY=

# Model overrides
FORGE_MODEL=claude-fable-5

# Local model (Ollama) — privacy gateway + embeddings
FORGE_OLLAMA_URL=http://localhost:11434
FORGE_LOCAL_MODEL=gemma3:4b
FORGE_EMBED_MODEL=nomic-embed-text
FORGE_OLLAMA_TIMEOUT_MS=60000

# Server
FORGE_PORT=3000
FORGE_HOST=127.0.0.1

# Storage
FORGE_DB_PATH=./data/forge.db

# Privacy — investor type ("pension") is sent next to masked names to aid
# drafting; jurisdiction is NOT, because type + jurisdiction together can
# re-identify an LP in a small fund. Set to 1 to opt in.
FORGE_SEND_JURISDICTION=0
